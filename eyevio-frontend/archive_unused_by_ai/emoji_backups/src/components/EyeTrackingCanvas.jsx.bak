import { useEffect, useRef, useState } from 'react'
import { toast } from 'react-hot-toast'

function EyeTrackingCanvas({ stage, onComplete }) {
  const canvasRef = useRef(null)
  const videoRef = useRef(null)
  const streamRef = useRef(null)
  const [isActive, setIsActive] = useState(false)
  const [cameraActive, setCameraActive] = useState(false)
  const [cameraError, setCameraError] = useState(null)
  const [progress, setProgress] = useState(0)
  const [message, setMessage] = useState('')
  const [userInput, setUserInput] = useState({ tracking: false, missCount: 0 })
  const animationRef = useRef(null)
  const startTimeRef = useRef(null)
  const performanceRef = useRef({ successFrames: 0, totalFrames: 0, missedTargets: 0 })
  const inputStateRef = useRef({ isTracking: false, lastInputTime: 0 })

  // Test durations in seconds
  const DURATIONS = {
    'smooth-pursuit': 15,
    'saccades': 10,
    'fixation': 10
  }

  const duration = DURATIONS[stage] || 10

  // Cleanup on unmount
  useEffect(() => {
    return () => {
      stopCamera()
      if (animationRef.current) {
        cancelAnimationFrame(animationRef.current)
      }
    }
  }, [])

  // Keyboard controls for tracking
  useEffect(() => {
    const handleKeyDown = (e) => {
      if (!isActive) return
      
      if (e.code === 'Space') {
        e.preventDefault()
        inputStateRef.current.isTracking = true
        inputStateRef.current.lastInputTime = Date.now()
        setUserInput(prev => ({ ...prev, tracking: true }))
      }
    }

    const handleKeyUp = (e) => {
      if (!isActive) return
      
      if (e.code === 'Space') {
        e.preventDefault()
        inputStateRef.current.isTracking = false
        setUserInput(prev => ({ ...prev, tracking: false }))
      }
    }

    window.addEventListener('keydown', handleKeyDown)
    window.addEventListener('keyup', handleKeyUp)

    return () => {
      window.removeEventListener('keydown', handleKeyDown)
      window.removeEventListener('keyup', handleKeyUp)
    }
  }, [isActive])

  const startCamera = async () => {
    console.log('🎥 Starting camera...')
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ 
        video: { 
          width: { ideal: 1280 },
          height: { ideal: 720 },
          facingMode: 'user'
        },
        audio: false
      })
      
      console.log(' Camera stream obtained:', stream)
      streamRef.current = stream
      
      // Wait for next tick to ensure video element is rendered
      setTimeout(() => {
        if (videoRef.current && streamRef.current) {
          console.log(' Setting video source...')
          videoRef.current.srcObject = streamRef.current
          videoRef.current.onloadedmetadata = () => {
            console.log(' Video metadata loaded, attempting to play...')
            videoRef.current.play()
              .then(() => {
                console.log('▶ Video playing successfully!')
                setCameraActive(true)
                setCameraError(null)
                toast.success('Camera activated for eye tracking!')
              })
              .catch(err => {
                console.error(' Error playing video:', err)
                setCameraError('Failed to play video stream')
              })
          }
        } else {
          console.error(' Video ref or stream ref is null')
        }
      }, 100)
    } catch (error) {
      console.error(' Failed to access camera:', error)
      let errorMessage = 'Failed to access camera.'
      
      if (error.name === 'NotAllowedError') {
        errorMessage = 'Camera access denied. Please allow camera permissions.'
      } else if (error.name === 'NotFoundError') {
        errorMessage = 'No camera found on this device.'
      } else if (error.name === 'NotReadableError') {
        errorMessage = 'Camera is already in use.'
      }
      
      setCameraError(errorMessage)
      toast.error(errorMessage)
    }
  }

  const stopCamera = () => {
    if (streamRef.current) {
      streamRef.current.getTracks().forEach(track => track.stop())
      streamRef.current = null
    }
    setCameraActive(false)
    if (videoRef.current) {
      videoRef.current.srcObject = null
    }
  }

  useEffect(() => {
    const canvas = canvasRef.current
    if (!canvas) return

    const ctx = canvas.getContext('2d')
    const rect = canvas.getBoundingClientRect()
    canvas.width = rect.width
    canvas.height = rect.height

    let targetX = canvas.width / 2
    let targetY = canvas.height / 2
    let targetVelX = 2
    let targetVelY = 1.5
    let saccadeTargets = []
    let currentSaccadeIndex = 0

    const drawTarget = (x, y, radius = 20, color = '#3b82f6') => {
      // Outer ring
      ctx.beginPath()
      ctx.arc(x, y, radius, 0, Math.PI * 2)
      ctx.strokeStyle = color
      ctx.lineWidth = 3
      ctx.stroke()

      // Middle ring
      ctx.beginPath()
      ctx.arc(x, y, radius * 0.6, 0, Math.PI * 2)
      ctx.strokeStyle = color
      ctx.lineWidth = 2
      ctx.stroke()

      // Center dot
      ctx.beginPath()
      ctx.arc(x, y, radius * 0.2, 0, Math.PI * 2)
      ctx.fillStyle = color
      ctx.fill()
    }

    const generateSaccadeTargets = () => {
      const targets = []
      const margin = 80
      const positions = [
        { x: margin, y: margin }, // Top-left
        { x: canvas.width - margin, y: margin }, // Top-right
        { x: canvas.width / 2, y: canvas.height / 2 }, // Center
        { x: margin, y: canvas.height - margin }, // Bottom-left
        { x: canvas.width - margin, y: canvas.height - margin }, // Bottom-right
        { x: canvas.width / 2, y: margin }, // Top-center
        { x: canvas.width / 2, y: canvas.height - margin }, // Bottom-center
        { x: margin, y: canvas.height / 2 }, // Left-center
        { x: canvas.width - margin, y: canvas.height / 2 } // Right-center
      ]
      
      // Randomize order
      const shuffled = [...positions].sort(() => Math.random() - 0.5)
      return shuffled.slice(0, 8) // Use 8 targets
    }

    const animate = (timestamp) => {
      if (!startTimeRef.current) {
        startTimeRef.current = timestamp
      }

      const elapsed = (timestamp - startTimeRef.current) / 1000 // seconds
      const progressPercent = Math.min((elapsed / duration) * 100, 100)
      setProgress(progressPercent)

      if (elapsed >= duration) {
        // Test complete
        const successRate = performanceRef.current.totalFrames > 0
          ? performanceRef.current.successFrames / performanceRef.current.totalFrames
          : 0
        const score = Math.round(successRate * 100)
        
        console.log(' Test complete!')
        console.log(' Performance:', performanceRef.current)
        console.log(' Final score:', score)
        console.log('   Success frames:', performanceRef.current.successFrames)
        console.log('   Total frames:', performanceRef.current.totalFrames)
        console.log('   Success rate:', (successRate * 100).toFixed(1) + '%')
        
        setIsActive(false)
        stopCamera()
        onComplete(score)
        return
      }

      ctx.clearRect(0, 0, canvas.width, canvas.height)

      // Draw background grid for reference
      ctx.strokeStyle = '#e5e7eb'
      ctx.lineWidth = 1
      for (let i = 0; i < canvas.width; i += 50) {
        ctx.beginPath()
        ctx.moveTo(i, 0)
        ctx.lineTo(i, canvas.height)
        ctx.stroke()
      }
      for (let i = 0; i < canvas.height; i += 50) {
        ctx.beginPath()
        ctx.moveTo(0, i)
        ctx.lineTo(canvas.width, i)
        ctx.stroke()
      }

      if (stage === 'smooth-pursuit') {
        // Moving target - smooth circular motion
        const speed = 0.02
        const radiusX = (canvas.width / 2) - 100
        const radiusY = (canvas.height / 2) - 80
        const centerX = canvas.width / 2
        const centerY = canvas.height / 2
        
        targetX = centerX + Math.cos(elapsed * speed) * radiusX
        targetY = centerY + Math.sin(elapsed * speed) * radiusY
        
        drawTarget(targetX, targetY, 25, '#3b82f6')
        
        // Check if user is holding spacebar (indicating they're tracking)
        const isTracking = inputStateRef.current.isTracking
        performanceRef.current.totalFrames++
        if (isTracking) {
          performanceRef.current.successFrames++
        }
        
        // Visual feedback
        if (isTracking) {
          ctx.beginPath()
          ctx.arc(targetX, targetY, 35, 0, Math.PI * 2)
          ctx.strokeStyle = '#10b981'
          ctx.lineWidth = 3
          ctx.stroke()
        }

      } else if (stage === 'saccades') {
        // Quick jumps between targets
        if (saccadeTargets.length === 0) {
          saccadeTargets = generateSaccadeTargets()
          currentSaccadeIndex = 0
        }

        // Change target every 1.2 seconds
        const targetChangeInterval = 1.2
        const targetIndex = Math.floor(elapsed / targetChangeInterval) % saccadeTargets.length
        
        if (targetIndex !== currentSaccadeIndex) {
          // Target changed - check if user was tracking the previous one
          if (!inputStateRef.current.isTracking) {
            performanceRef.current.missedTargets++
          }
          currentSaccadeIndex = targetIndex
        }

        const currentTarget = saccadeTargets[currentSaccadeIndex]
        
        // Draw all targets faintly
        saccadeTargets.forEach((target, idx) => {
          if (idx !== currentSaccadeIndex) {
            drawTarget(target.x, target.y, 15, '#cbd5e1')
          }
        })
        
        // Draw current target prominently
        drawTarget(currentTarget.x, currentTarget.y, 25, '#ef4444')
        
        // Track performance
        const isTracking = inputStateRef.current.isTracking
        performanceRef.current.totalFrames++
        if (isTracking) {
          performanceRef.current.successFrames++
        }
        
        // Visual feedback
        if (isTracking) {
          ctx.beginPath()
          ctx.arc(currentTarget.x, currentTarget.y, 35, 0, Math.PI * 2)
          ctx.strokeStyle = '#10b981'
          ctx.lineWidth = 3
          ctx.stroke()
        }

      } else if (stage === 'fixation') {
        // Stationary center target
        const centerX = canvas.width / 2
        const centerY = canvas.height / 2
        drawTarget(centerX, centerY, 30, '#10b981')
        
        // Check if user is holding spacebar (maintaining fixation)
        const isTracking = inputStateRef.current.isTracking
        performanceRef.current.totalFrames++
        if (isTracking) {
          performanceRef.current.successFrames++
        }
        
        // Visual feedback
        if (isTracking) {
          ctx.beginPath()
          ctx.arc(centerX, centerY, 45, 0, Math.PI * 2)
          ctx.strokeStyle = '#10b981'
          ctx.lineWidth = 3
          ctx.stroke()
        }
      }

      // Draw progress bar
      const barHeight = 8
      const barY = canvas.height - 30
      ctx.fillStyle = '#e5e7eb'
      ctx.fillRect(20, barY, canvas.width - 40, barHeight)
      ctx.fillStyle = '#3b82f6'
      ctx.fillRect(20, barY, (canvas.width - 40) * (progressPercent / 100), barHeight)

      // Draw time remaining
      const timeLeft = Math.ceil(duration - elapsed)
      ctx.fillStyle = '#1f2937'
      ctx.font = 'bold 16px sans-serif'
      ctx.textAlign = 'center'
      ctx.fillText(`${timeLeft}s`, canvas.width / 2, canvas.height - 10)

      animationRef.current = requestAnimationFrame(animate)
    }

    if (isActive) {
      console.log('🎬 Starting animation loop for stage:', stage)
      animationRef.current = requestAnimationFrame(animate)
    }

    return () => {
      if (animationRef.current) {
        cancelAnimationFrame(animationRef.current)
      }
    }
  }, [isActive, stage, duration, onComplete, cameraActive])

  const startTest = () => {
    console.log(' Starting test for stage:', stage)
    
    // Start camera for monitoring (optional - can be removed if not needed)
    startCamera()
    
    setIsActive(true)
    startTimeRef.current = null
    performanceRef.current = { successFrames: 0, totalFrames: 0, missedTargets: 0 }
    inputStateRef.current = { isTracking: false, lastInputTime: 0 }
    setProgress(0)
    
    console.log(' Performance ref reset:', performanceRef.current)
    
    if (stage === 'smooth-pursuit') {
      setMessage('Hold SPACEBAR while your eyes follow the blue target')
    } else if (stage === 'saccades') {
      setMessage('Hold SPACEBAR when your eyes reach the red target')
    } else if (stage === 'fixation') {
      setMessage('Hold SPACEBAR while keeping your eyes on the green target')
    }
  }

  return (
    <div className="relative w-full h-full">
      {/* Hidden video element for webcam feed (optional monitoring) */}
      <video
        ref={videoRef}
        className="hidden"
        autoPlay
        playsInline
        muted
      />
      
      <canvas
        ref={canvasRef}
        className="w-full h-full bg-white rounded-lg"
        style={{ minHeight: '400px' }}
      />
      
      {cameraError && (
        <div className="absolute top-4 left-4 right-4 bg-yellow-50 border border-yellow-200 rounded-lg p-3">
          <div className="flex items-start space-x-2">
            <svg className="w-5 h-5 text-yellow-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div className="flex-1">
              <p className="text-sm font-semibold text-yellow-800">Camera Optional</p>
              <p className="text-sm text-yellow-700">Camera is for monitoring only. Use SPACEBAR to indicate tracking.</p>
            </div>
          </div>
        </div>
      )}
      
      {isActive && (
        <div className="absolute bottom-24 left-1/2 transform -translate-x-1/2 bg-white border-2 border-blue-600 px-6 py-3 rounded-lg shadow-lg">
          <div className="flex items-center space-x-3">
            <div className={`px-4 py-2 rounded font-mono font-bold text-lg ${
              userInput.tracking ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-700'
            }`}>
              SPACEBAR
            </div>
            <div className="text-sm text-gray-700">
              {userInput.tracking ? (
                <span className="text-green-600 font-semibold">✓ Tracking</span>
              ) : (
                <span>Hold while tracking target</span>
              )}
            </div>
          </div>
        </div>
      )}
      
      {!isActive && (
        <div className="absolute inset-0 flex items-center justify-center bg-white bg-opacity-90 rounded-lg">
          <div className="text-center max-w-md">
            <div className="w-16 h-16 mx-auto mb-4 bg-blue-100 rounded-full flex items-center justify-center">
              <svg className="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </div>
            <h3 className="text-xl font-bold text-gray-900 mb-2">
              {stage === 'smooth-pursuit' && 'Smooth Pursuit Test'}
              {stage === 'saccades' && 'Saccade Test'}
              {stage === 'fixation' && 'Fixation Stability Test'}
            </h3>
            <p className="text-gray-600 mb-4 text-sm">
              {stage === 'smooth-pursuit' && 'Follow the moving blue target smoothly with your eyes. Hold SPACEBAR while your eyes are tracking the target.'}
              {stage === 'saccades' && 'Quickly move your eyes to each red target as it appears. Hold SPACEBAR when you reach each target.'}
              {stage === 'fixation' && 'Keep your eyes fixed on the green center target. Hold SPACEBAR while maintaining steady fixation.'}
            </p>
            
            <div className="mb-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
              <p className="text-sm font-semibold text-blue-900 mb-2">How it works:</p>
              <div className="text-left text-sm text-blue-800 space-y-1">
                <p>• Look at the target with your eyes</p>
                <p>• Hold down the <span className="font-mono font-bold">SPACEBAR</span> while tracking</p>
                <p>• Release when you lose track of the target</p>
                <p>• Your score = % of time successfully tracking</p>
              </div>
            </div>
            
            <button
              onClick={startTest}
              className="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-full transition-colors"
            >
              Start {stage === 'smooth-pursuit' ? 'Pursuit' : stage === 'saccades' ? 'Saccade' : 'Fixation'} Test
            </button>
          </div>
        </div>
      )}
      
      {isActive && message && (
        <div className="absolute top-4 left-1/2 transform -translate-x-1/2 bg-blue-600 text-white px-6 py-2 rounded-full shadow-lg font-semibold">
          {message}
        </div>
      )}
    </div>
  )
}

export default EyeTrackingCanvas
