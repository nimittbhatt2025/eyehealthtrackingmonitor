/**
 * Eye Coverage Detection Utility
 * Uses MediaPipe Face Mesh + Hands for robust occlusion detection
 * 
 * Detection Strategy:
 * 1. Hand Detection (PRIMARY) - Detect if hand overlaps eye region
 * 2. EAR (SECONDARY) - Detect eye closure/squinting
 */

import { FaceMesh } from '@mediapipe/face_mesh'
import { Hands } from '@mediapipe/hands'

export class EyeCoverageDetector {
  constructor(videoElement) {
    this.video = videoElement
    this.canvas = document.createElement('canvas')
    this.ctx = this.canvas.getContext('2d')
    this.isActive = false
    this.faceMesh = null
    this.hands = null
    this.lastResults = null // Store latest face detection results
    this.lastHandResults = null // Store latest hand detection results
    this.lastDetection = { left: true, right: true } // visible by default
    this.baselineFace = null // Store baseline face position when both eyes visible
    this.faceDetectionCount = 0 // Track consecutive face detections
  }
  
  async initialize() {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ 
        video: { facingMode: 'user', width: 640, height: 480 } 
      })
      this.video.srcObject = stream
      this.video.play()
      
      // Initialize MediaPipe Face Mesh
      this.faceMesh = new FaceMesh({
        locateFile: (file) => {
          return `https://cdn.jsdelivr.net/npm/@mediapipe/face_mesh/${file}`
        }
      })
      
      this.faceMesh.setOptions({
        maxNumFaces: 1,
        refineLandmarks: true,
        minDetectionConfidence: 0.5,
        minTrackingConfidence: 0.5
      })
      
      // Set up results callback
      this.faceMesh.onResults((results) => {
        this.lastResults = results
      })
      
      // Initialize MediaPipe Hands with proper CDN path
      this.hands = new Hands({
        locateFile: (file) => {
          // Use unpkg CDN which has better reliability
          return `https://unpkg.com/@mediapipe/hands@0.4.1646424915/${file}`
        }
      })
      
      this.hands.setOptions({
        selfieMode: false,
        maxNumHands: 2,
        modelComplexity: 0,  // Use lite model (faster, less accurate but sufficient)
        minDetectionConfidence: 0.5,
        minTrackingConfidence: 0.5
      })
      
      this.hands.onResults((results) => {
        this.lastHandResults = results
      })
      
      console.log('✅ MediaPipe Face Mesh initialized')
      console.log('✅ MediaPipe Hands initialized (attempting to load models...)')
      
      // Wait for video to be ready
      return new Promise((resolve) => {
        this.video.onloadedmetadata = () => {
          this.canvas.width = this.video.videoWidth
          this.canvas.height = this.video.videoHeight
          this.isActive = true
          console.log('✅ Video ready:', this.canvas.width, 'x', this.canvas.height)
          resolve(true)
        }
      })
    } catch (error) {
      console.error('Failed to access webcam:', error)
      return false
    }
  }
  
  
  /**
   * Detect which eye is covered based on facial landmarks visibility
   * Returns: 'left', 'right', 'both', or 'neither'
   */
  
  /**
   * Establish baseline face position (call this first!)
   * Ensures face is detected and both eyes are visible before starting detection
   * Returns: { success: boolean, message: string }
   */
  async establishBaseline() {
    console.log('🎯 Establishing baseline face position...')
    
    for (let attempt = 0; attempt < 10; attempt++) {
      await this.faceMesh.send({ image: this.video })
      
      if (!this.lastResults || !this.lastResults.multiFaceLandmarks || this.lastResults.multiFaceLandmarks.length === 0) {
        console.warn(`❌ Attempt ${attempt + 1}/10: No face detected`)
        await new Promise(resolve => setTimeout(resolve, 200)) // Wait 200ms between attempts
        continue
      }
      
      const landmarks = this.lastResults.multiFaceLandmarks[0]
      
      // Calculate Eye Aspect Ratio for both eyes
      // SWAPPED for mirrored video: MediaPipe "right" = User's LEFT, MediaPipe "left" = User's RIGHT
      const leftEyeEAR = this.calculateEyeAspectRatio(landmarks, {
        p1: 362, p2: 387, p3: 386, p4: 263, p5: 374, p6: 373  // User's LEFT = MediaPipe RIGHT
      })
      
      const rightEyeEAR = this.calculateEyeAspectRatio(landmarks, {
        p1: 33, p2: 160, p3: 159, p4: 133, p5: 145, p6: 144  // User's RIGHT = MediaPipe LEFT
      })
      
      // Both eyes should have normal EAR (> 0.15 means eyes are open and visible)
      if (leftEyeEAR > 0.15 && rightEyeEAR > 0.15) {
        // Success! Store baseline
        this.baselineFace = {
          landmarks: landmarks.map(l => ({ x: l.x, y: l.y, z: l.z })),
          leftEyeEAR: leftEyeEAR,
          rightEyeEAR: rightEyeEAR,
          timestamp: Date.now()
        }
        
        console.log('✅ Baseline established!', {
          leftEyeEAR: leftEyeEAR.toFixed(4),
          rightEyeEAR: rightEyeEAR.toFixed(4),
          landmarkCount: landmarks.length,
          note: 'Normal EAR range: 0.2-0.3'
        })
        
        return {
          success: true,
          message: 'Face detected! Both eyes visible.'
        }
      } else {
        console.warn(`❌ Attempt ${attempt + 1}/10: Eyes not clearly open`, {
          leftEAR: leftEyeEAR.toFixed(4),
          rightEAR: rightEyeEAR.toFixed(4),
          threshold: 0.15,
          note: 'Please open your eyes wide and look at camera'
        })
      }
      
      await new Promise(resolve => setTimeout(resolve, 200))
    }
    
    return {
      success: false,
      message: 'Could not detect face with both eyes visible. Please ensure your face is clearly visible and well-lit.'
    }
  }
  
  /**
   * Detect which eye is covered based on facial landmarks visibility
   * REQUIRES: establishBaseline() must be called first!
   * Returns: 'left', 'right', 'both', or 'neither'
   */
  async detectCoveredEye() {
    if (!this.isActive || !this.video.videoWidth || !this.faceMesh) {
      console.warn('🔍 Detection not ready:', {
        isActive: this.isActive,
        hasVideo: !!this.video.videoWidth,
        hasFaceMesh: !!this.faceMesh
      })
      return 'unknown'
    }
    
    if (!this.baselineFace) {
      console.warn('⚠️ No baseline established! Call establishBaseline() first')
      return 'unknown'
    }
    
    try {
      // Send current video frame to BOTH MediaPipe models
      await Promise.all([
        this.faceMesh.send({ image: this.video }),
        this.hands.send({ image: this.video })
      ])
      
      // Wait for processing
      await new Promise(resolve => setTimeout(resolve, 100))
      
      // Draw to canvas for brightness sampling
      this.ctx.drawImage(this.video, 0, 0)
      const imageData = this.ctx.getImageData(0, 0, this.canvas.width, this.canvas.height)
      
      // Check if we got face detection results
      if (!this.lastResults || !this.lastResults.multiFaceLandmarks || this.lastResults.multiFaceLandmarks.length === 0) {
        console.warn('⚠️ No face detected')
        return 'neither'
      }
      
      const landmarks = this.lastResults.multiFaceLandmarks[0]
      
      // ====================
      // STEP 1: HAND DETECTION (PRIMARY) - Standard clinical practice
      // ====================
      // Hand/palm coverage is the CORRECT way to test monocular vision
      
      const leftEyeIndices = [362, 263, 387, 386, 374, 373]
      const rightEyeIndices = [33, 133, 160, 159, 145, 144]
      
      const leftEyeBox = this.getEyeBoundingBox(landmarks, leftEyeIndices)
      const rightEyeBox = this.getEyeBoundingBox(landmarks, rightEyeIndices)
      const handOverlap = this.checkHandEyeOverlap(leftEyeBox, rightEyeBox)
      
      console.log('👋 Hand Detection:', {
        handsDetected: this.lastHandResults?.multiHandLandmarks?.length || 0,
        leftEyeOverlap: handOverlap.left ? '🚫 HAND BLOCKING' : '✅ Clear',
        rightEyeOverlap: handOverlap.right ? '🚫 HAND BLOCKING' : '✅ Clear'
      })
      
      if (handOverlap.left && handOverlap.right) {
        console.log('🟣 RESULT: Both eyes covered (hand detection)')
        return 'both'
      }
      if (handOverlap.left) {
        console.log('🔵 RESULT: LEFT eye covered (hand detection)')
        return 'left'
      }
      if (handOverlap.right) {
        console.log('🔴 RESULT: RIGHT eye covered (hand detection)')
        return 'right'
      }
      
      // ====================
      // STEP 2: EYE ASPECT RATIO (SECONDARY) - Fallback for closed eyes
      // ====================
      
      // Calculate EAR for both eyes
      const leftEyeEAR = this.calculateEyeAspectRatio(landmarks, {
        p1: 362,  // outer corner (MediaPipe RIGHT = User's LEFT)
        p2: 387,  // top
        p3: 386,  // top-mid
        p4: 263,  // inner corner
        p5: 374,  // bottom
        p6: 373   // bottom-mid
      })
      
      const rightEyeEAR = this.calculateEyeAspectRatio(landmarks, {
        p1: 33,   // outer corner (MediaPipe LEFT = User's RIGHT)
        p2: 160,  // top
        p3: 159,  // top-mid
        p4: 133,  // inner corner
        p5: 145,  // bottom
        p6: 144   // bottom-mid
      })
      
      // Use absolute EAR threshold
      const EAR_THRESHOLD = 0.15
      
      const leftCovered = leftEyeEAR < EAR_THRESHOLD
      const rightCovered = rightEyeEAR < EAR_THRESHOLD
      
      console.log('👁️  EAR Detection:', {
        leftEye: {
          EAR: leftEyeEAR.toFixed(3),
          status: leftCovered ? '🔵 COVERED/CLOSED' : '✅ Open',
          threshold: EAR_THRESHOLD
        },
        rightEye: {
          EAR: rightEyeEAR.toFixed(3),
          status: rightCovered ? '🔴 COVERED/CLOSED' : '✅ Open',
          threshold: EAR_THRESHOLD
        }
      })
      
      if (leftCovered && rightCovered) {
        console.log('� RESULT: Both eyes covered')
        return 'both'
      }
      
      if (leftCovered) {
        console.log('🔵 RESULT: LEFT eye covered (left side of screen)')
        return 'left'
      }
      
      if (rightCovered) {
        console.log('🔴 RESULT: RIGHT eye covered (right side of screen)')
        return 'right'
      }
      
      console.log('🟢 RESULT: Neither eye covered (both visible)')
      return 'neither'
      
    } catch (error) {
      console.error('💥 Detection error:', error)
      return 'unknown'
    }
  }

  /**
   * Calculate Eye Aspect Ratio (EAR)
   * Formula: EAR = (||p2-p6|| + ||p3-p5||) / (2 * ||p1-p4||)
   * When eye is open: EAR ≈ 0.2-0.3
   * When eye is closed/squinted: EAR ≈ 0-0.15
   */
  calculateEyeAspectRatio(landmarks, points) {
    const p1 = landmarks[points.p1]
    const p2 = landmarks[points.p2]
    const p3 = landmarks[points.p3]
    const p4 = landmarks[points.p4]
    const p5 = landmarks[points.p5]
    const p6 = landmarks[points.p6]
    
    // Calculate Euclidean distances
    const distance = (a, b) => {
      const dx = a.x - b.x
      const dy = a.y - b.y
      return Math.sqrt(dx * dx + dy * dy)
    }
    
    // Vertical distances
    const vertical1 = distance(p2, p6)
    const vertical2 = distance(p3, p5)
    
    // Horizontal distance
    const horizontal = distance(p1, p4)
    
    // EAR formula
    const ear = (vertical1 + vertical2) / (2.0 * horizontal)
    
    return ear
  }

  /**
   * Verify correct eye is covered for monocular testing
   * expectedCovered: 'left' or 'right'
   */
  async verifyCoverage(expectedCovered) {
    const detected = await this.detectCoveredEye()
    
    return {
      detected,
      correct: detected === expectedCovered,
      message: this.getCoverageMessage(detected, expectedCovered)
    }
  }
  
  /**
   * Calculate bounding box for an eye region
   * @param {Array} landmarks - Face mesh landmarks
   * @param {Array} eyeIndices - Indices of eye landmarks
   * @returns {Object} Bounding box with x, y, width, height
   */
  getEyeBoundingBox(landmarks, eyeIndices) {
    const xs = eyeIndices.map(i => landmarks[i].x)
    const ys = eyeIndices.map(i => landmarks[i].y)
    
    const minX = Math.min(...xs)
    const maxX = Math.max(...xs)
    const minY = Math.min(...ys)
    const maxY = Math.max(...ys)
    
    return {
      x: minX,
      y: minY,
      width: maxX - minX,
      height: maxY - minY,
      x2: maxX, // For easier overlap calculation
      y2: maxY
    }
  }

  /**
   * Check if any detected hand overlaps with eye regions
   * Uses Intersection over Union (IoU) with 30-40% threshold
   * @param {Object} leftEyeBox - Left eye bounding box
   * @param {Object} rightEyeBox - Right eye bounding box
   * @returns {Object} { left: boolean, right: boolean }
   */
  checkHandEyeOverlap(leftEyeBox, rightEyeBox) {
    const result = { left: false, right: false }
    
    // No hand detected
    if (!this.lastHandResults || !this.lastHandResults.multiHandLandmarks) {
      return result
    }
    
    const OVERLAP_THRESHOLD = 0.35 // 35% overlap = covered
    
    // Check each detected hand
    for (const handLandmarks of this.lastHandResults.multiHandLandmarks) {
      // Calculate hand bounding box
      const handXs = handLandmarks.map(lm => lm.x)
      const handYs = handLandmarks.map(lm => lm.y)
      
      const handBox = {
        x: Math.min(...handXs),
        y: Math.min(...handYs),
        x2: Math.max(...handXs),
        y2: Math.max(...handYs)
      }
      
      // Calculate overlap with left eye
      const leftIntersection = this.calculateIntersection(handBox, leftEyeBox)
      const leftEyeArea = leftEyeBox.width * leftEyeBox.height
      const leftOverlap = leftIntersection / leftEyeArea
      
      if (leftOverlap > OVERLAP_THRESHOLD) {
        result.left = true
      }
      
      // Calculate overlap with right eye
      const rightIntersection = this.calculateIntersection(handBox, rightEyeBox)
      const rightEyeArea = rightEyeBox.width * rightEyeBox.height
      const rightOverlap = rightIntersection / rightEyeArea
      
      if (rightOverlap > OVERLAP_THRESHOLD) {
        result.right = true
      }
    }
    
    return result
  }

  /**
   * Calculate intersection area between two bounding boxes
   * @param {Object} box1 - First box with x, y, x2, y2
   * @param {Object} box2 - Second box with x, y, x2, y2
   * @returns {number} Intersection area
   */
  calculateIntersection(box1, box2) {
    const xOverlap = Math.max(0, Math.min(box1.x2, box2.x2) - Math.max(box1.x, box2.x))
    const yOverlap = Math.max(0, Math.min(box1.y2, box2.y2) - Math.max(box1.y, box2.y))
    return xOverlap * yOverlap
  }

  getCoverageMessage(detected, expected) {
    if (detected === 'unknown') {
      return 'Unable to detect eye coverage. Please ensure webcam access is granted.'
    }
    
    if (detected === expected) {
      return `✓ Correct: ${expected === 'left' ? 'Left' : 'Right'} eye covered.`
    }
    
    if (detected === 'neither') {
      return `Please cover your ${expected === 'left' ? 'LEFT' : 'RIGHT'} eye with your palm.`
    }
    
    if (detected === 'both') {
      return 'Both eyes appear covered. Please cover only your ' + 
             `${expected === 'left' ? 'LEFT' : 'RIGHT'} eye.`
    }
    
    // Wrong eye covered - tell them which eye to cover (the expected one)
    return `Wrong eye covered. Please cover your ${expected === 'left' ? 'LEFT' : 'RIGHT'} eye instead.`
  }
  
  stop() {
    // Cleanup MediaPipe Face Mesh
    if (this.faceMesh) {
      this.faceMesh.close()
      this.faceMesh = null
    }
    
    // Cleanup MediaPipe Hands
    if (this.hands) {
      this.hands.close()
      this.hands = null
    }
    
    // Stop webcam
    if (this.video.srcObject) {
      this.video.srcObject.getTracks().forEach(track => track.stop())
      this.video.srcObject = null
    }
    
    this.isActive = false
  }
}

export default EyeCoverageDetector
